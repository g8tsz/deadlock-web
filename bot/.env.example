DISCORD_BOT_TOKEN=
# Application ID (from Discord Developer Portal — same app as the bot)
DISCORD_CLIENT_ID=
# Optional: register slash commands only in this guild (faster while developing)
DISCORD_GUILD_ID=

# Comma-separated Discord role IDs allowed to run ingest commands
DISCORD_ADMIN_ROLE_IDS=

# Base URL of the Next.js site (no trailing slash)
INGEST_BASE_URL=https://collegedeadlock.com
# Same value as BOT_INGEST_SECRET on the website
BOT_INGEST_SECRET=

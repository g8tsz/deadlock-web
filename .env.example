# Local dev (SQLite file):
# DATABASE_URL="file:./prisma/dev.db"
# Production or Docker local Postgres:
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"
DATABASE_URL="file:./prisma/dev.db"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
DISCORD_CLIENT_ID="your-discord-app-client-id"
DISCORD_CLIENT_SECRET="your-discord-app-client-secret"

# Ingest API for Discord bot (generate a long random string)
BOT_INGEST_SECRET="generate-a-long-random-secret-for-bot-only"

# Canonical site URL for sitemap/OG (production: https://collegedeadlock.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Local dev (SQLite file):
# DATABASE_URL="file:./prisma/dev.db"
# Production or Docker local Postgres:
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"
DATABASE_URL="file:./prisma/dev.db"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
DISCORD_CLIENT_ID="your-discord-app-client-id"
DISCORD_CLIENT_SECRET="your-discord-app-client-secret"

# Ingest API for Discord bot (generate a long random string). Never expose in the browser.
BOT_INGEST_SECRET="generate-a-long-random-secret-for-bot-only"

# Optional: comma-separated IPs allowed to call ingest after bearer auth (e.g. bot host).
# If unset, any IP is allowed once the secret is valid. Use "*" to document "any" explicitly (same as unset).
# BOT_INGEST_ALLOWED_IPS="203.0.113.10,198.51.100.2"

# Canonical site URL for sitemap/OG (production: https://your-domain.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Discord incoming webhook URL for contact + newsletter forms (server-side only).
# Create: Server Settings → Integrations → Webhooks → New Webhook, copy URL.
# If unset: production returns 503 for form POSTs; local dev logs to the terminal instead.
# FORMS_DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/.../..."

# Optional: Cloudflare Turnstile (set BOTH for production forms). Site key is public; secret is server-only.
# https://developers.cloudflare.com/turnstile/get-started/
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAA..."
# TURNSTILE_SECRET_KEY="0x4AAAAAA..."
